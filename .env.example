KV_REST_API_URL=...
KV_REST_API_TOKEN=...

# === Storage ===
BLOB_READ_WRITE_TOKEN=...              # Vercel Blob for HAR files

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
