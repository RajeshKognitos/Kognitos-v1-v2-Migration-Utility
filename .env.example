# === OpenAI ===
OPENAI_API_KEY=sk-...

# === Kognitos v2 ===
KOGNITOS_PAT=...                       # Personal Access Token
KOGNITOS_ORG_ID=...                    # Default org for migrations
KOGNITOS_WORKSPACE_ID=...              # Default workspace
KOGNITOS_MCP_URL=https://mcp.us-1.kognitos.com/
KOGNITOS_API_BASE=https://app.us-1.kognitos.com

# === Persistence ===
# Backend selection (optional). If unset: uses Supabase when the two SUPABASE_*
# vars below are present, otherwise falls back to local SQLite for dev.
#   MIGRATION_STORE=supabase | sqlite | memory
MIGRATION_STORE=

# Supabase (production). Apply supabase/schema.sql once, then set:
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...          # service_role key — server-side only, never expose to the client

# Local dev SQLite (used when Supabase isn't configured). Optional path override:
# MIGRATION_DB_PATH=./data/migrations.db

# === Storage ===
BLOB_READ_WRITE_TOKEN=...              # Vercel Blob for HAR files

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
